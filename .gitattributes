# Line ending configuration for cross-platform compatibility

# Shell scripts should use LF
*.sh text eol=lf

# PowerShell scripts should use CRLF
*.ps1 text eol=crlf

# Python files should use LF
*.py text eol=lf

# YAML files should use LF
*.yaml text eol=lf
*.yml text eol=lf

# Markdown files
*.md text eol=lf

# Docker files
Dockerfile text eol=lf
docker-compose.yml text eol=lf
